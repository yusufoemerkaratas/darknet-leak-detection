# collectors/.env.example
# Copy this file to collectors/.env and fill in the real values.
# Never commit .env to version control.

# BreachForums credentials
BREACHFORUMS_USER=your_username_here
BREACHFORUMS_PASS=your_password_here

# XSS.is credentials
XSSFORUM_USER=your_username_here
XSSFORUM_PASS=your_password_here

# Exploit.in credentials
EXPLOITIN_USER=your_username_here
EXPLOITIN_PASS=your_password_here

# Tor settings (defaults match standard Tor installation)
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
# Leave empty if CookieAuthentication is used (no password)
TOR_CONTROL_PASSWORD=

# Captcha solver — Ollama instance accessible via SSH tunnel
# ssh -L 9999:localhost:11434 -N user@server-ip
OLLAMA_URL=http://localhost:9999
OLLAMA_CAPTCHA_MODEL=qwen3-vl:32b
