# Copy this file to .env and fill in the real values.
# Never commit .env to version control.

# Database — "db" is the Docker service name, used as hostname inside the container network
DATABASE_URL=postgresql+psycopg2://postgres:password@db:5432/datenleck_db

# Ports exposed on the HOST machine:
#   frontend → http://localhost:62000
#   backend  → http://localhost:62001
#   db       → localhost:5433  (5432 avoided — may conflict with a local Postgres)
FRONTEND_PORT=62000
BACKEND_PORT=62001

# Tor
TOR_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=

# Captcha solver (Ollama Vision)
OLLAMA_CAPTCHA_MODEL=qwen3-vl:32b
OLLAMA_URL=http://localhost:9999

# Optional LLM enrichment for leak analysis.
# Keep disabled unless the school LLM endpoint is reachable locally or through an SSH tunnel.
LLM_ANALYSIS_ENABLED=false
LLM_ANALYSIS_URL=http://localhost:9999/api/generate
LLM_ANALYSIS_MODEL=llama3.1
LLM_ANALYSIS_TIMEOUT=30

# Paste.ee API key (optional — scraping fallback works without it)
PASTEEE_API_KEY=replace_with_real_key
